# All optional — the app runs demo-mode without any of these.
DATABASE_URL=            # Neon Postgres connection string (run sql/001_schema.sql + sql/002_seed.sql first)
STRIPE_SECRET_KEY=       # live invoice payments (mock checkout without it)
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=          # transactional email (no-op without it)
EMAIL_FROM=
ANTHROPIC_API_KEY=       # /dashboard "Platform briefing" card (the card says it's off without it)
CRON_SECRET=             # guards /api/cron/* — Vercel Cron sends it as `Authorization: Bearer $CRON_SECRET`.
                         # Generate with `openssl rand -hex 32`. UNSET = the endpoint refuses everyone
                         # (503), never "open to anyone" — it spends real database time.
